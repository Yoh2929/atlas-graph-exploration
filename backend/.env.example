NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123

POSTGRES_URL=postgresql://atlas:atlas@postgres:5432/atlas

JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Seed v2: automated, bounded mathematical discovery
ATLAS_SEED_MAX_NODES=2000
ATLAS_SEED_MAX_EDGES=15000
ATLAS_SEED_WIKIPEDIA_DEPTH=2
ATLAS_SEED_WIKIPEDIA_LANGUAGE=en
ATLAS_SEED_HTTP_TIMEOUT=30
ATLAS_SEED_HTTP_RETRIES=5
ATLAS_SEED_CACHE_TTL_SECONDS=86400
ATLAS_SEED_REFRESH_CACHE=false
ATLAS_SEED_CACHE_DIR=.seed-cache
ATLAS_SEED_ARTIFACT_DIR=seed-artifacts
# Optional: semicolon-separated "Wikipedia category|display family" entries
# ATLAS_SEED_WIKIPEDIA_ROOTS=Category:Mathematics|domain;Category:Mathematicians|person
# Optional: pages-index dont les liens servent à découvrir des sujets majeurs
